rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Usuário autenticado pode ler e escrever apenas o próprio documento
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Admin (role 0) pode listar todos os usuários
      allow list: if request.auth != null
                  && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 0;
    }

    match /companies/{companyId} {
      // Qualquer usuário autenticado pode ler empresas (necessário para o mapa)
      allow read: if request.auth != null;

      // Somente admin (role 0) pode criar, editar e excluir empresas
      allow write: if request.auth != null
                   && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 0;
    }

  }
}
